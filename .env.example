# Frontend (Vite build-time — exposed in browser bundle)
VITE_SOLANA_NETWORK=mainnet
VITE_SOLANA_RPC_MAINNET=https://mainnet.helius-rpc.com/?api-key=PASTE_KEY_HERE
VITE_SOLANA_RPC_DEVNET=https://devnet.helius-rpc.com/?api-key=PASTE_KEY_HERE

# API serverless (Vercel runtime — not exposed to browser)
HELIUS_MAINNET_API_KEY=PASTE_KEY_HERE
HELIUS_DEVNET_API_KEY=PASTE_KEY_HERE

# Optional overrides
VITE_CBS_LOCKER_PROGRAM_ID=
VITE_LOCK_API_BASE=/api/v1
